#%PAM-1.0
#
# Pile PAM de base, dérivée de celle fournie par le paquet pambase, avec
# l'intégration SSSD/Active Directory ajoutée (cf. ArchWiki "LDAP
# authentication#PAM configuration"). Ce fichier remplace celui livré par
# pambase — pacman le protègera comme un fichier de config existant lors
# de l'installation du paquet (un éventuel .pacnew apparaîtra en cas de
# mise à jour de pambase à surveiller manuellement).
#
# Tous les services (login, sddm, sudo, su, sshd...) incluent system-auth
# via system-login, donc les utilisateurs du domaine AD peuvent s'authentifier
# partout une fois `realm join` effectué, sans configuration supplémentaire.

auth       sufficient   pam_sss.so        forward_pass
auth       required     pam_unix.so       try_first_pass nullok
auth       optional     pam_permit.so
auth       required     pam_env.so

account    [default=bad success=ok user_unknown=ignore authinfo_unavail=ignore] pam_sss.so
account    required     pam_unix.so
account    optional     pam_permit.so
account    required     pam_time.so

password   sufficient   pam_sss.so
password   required     pam_unix.so       try_first_pass nullok shadow
password   optional     pam_permit.so

# Crée le home dir au premier login d'un utilisateur AD (module standard
# fourni par le paquet `pam`, aucune dépendance supplémentaire requise).
session    required     pam_mkhomedir.so  skel=/etc/skel umask=0077
session    required     pam_limits.so
session    required     pam_unix.so
session    optional     pam_sss.so
session    optional     pam_permit.so
